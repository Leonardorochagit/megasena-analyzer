# Configuração de usuários para Streamlit Cloud
# IMPORTANTE: Configure isso no painel do Streamlit Cloud em Settings > Secrets

[usuarios.leonardo]
senha = "mega2025"
nome = "Leonardo"
email = "leonardo@example.com"
admin = true

[usuarios.demo]
senha = "demo123"
nome = "Usuário Demo"
email = "demo@example.com"
admin = false

# Para adicionar novos usuários, copie o padrão acima:
# [usuarios.SEU_USUARIO]
# senha = "sua_senha"
# nome = "Seu Nome"
# email = "seu@email.com"
# admin = false

# ── Notificações WhatsApp (CallMeBot) ──────────────────────
# Obtenha sua apikey enviando "I allow callmebot to send me messages"
# para +34 644 59 71 67 no WhatsApp
[whatsapp]
telefone = "5511999999999"
apikey = "SEU_APIKEY_AQUI"
